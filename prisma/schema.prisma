generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id     String  @id @default(cuid())
  email  String  @unique
  name   String?
  boards Board[]
}

model Board {
  id        String   @id @default(cuid())
  title     String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  x         Float    @default(150) // 
  y         Float    @default(150) //

  parentId  String?  
  parent    Board?   @relation("SubBoards", fields: [parentId], references: [id], onDelete: Cascade)
  subBoards Board[]  @relation("SubBoards")
  notes     Note[]
  createdAt DateTime @default(now())
  todos     Todo[]
  todoLists TodoList[]
 
}

model Note {
  id        String   @id @default(cuid())
  content   String
  x         Float // Position X (für Drag & Drop)
  y         Float // Position Y
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TodoList {
  id        String   @id @default(uuid())
  title     String   @default("Neue To-Do Liste")
  x         Float
  y         Float
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id])
  todos     Todo[] // Verknüpfung zu den einzelnen Todos
  createdAt DateTime @default(now())
}

model Todo {
  id         String   @id @default(uuid())
  content    String
  completed  Boolean  @default(false)
  todoListId String   
  todoList   TodoList @relation(fields: [todoListId], references: [id], onDelete: Cascade) 
  boardId    String
  board      Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}
